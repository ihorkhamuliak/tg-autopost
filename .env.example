# ── Telegram MTProto (userbot) ──────────────────────────────────────────────
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+380XXXXXXXXX

# ── Source channels (без @, через кому) ──────────────────────────────────────
SOURCE_CHANNELS=source_channel_1,source_channel_2,source_channel_3

# ── n8n webhook ───────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://YOUR_VPS_IP:5678/webhook/YOUR_WEBHOOK_ID

# ── Target channel ────────────────────────────────────────────────────────────
CHANNEL_ID=-100XXXXXXXXXX
CHANNEL_LINK=https://t.me/+XXXXXXXXXXXX
CHANNEL_NAME=Назва_Каналу

# ── Bot publisher ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Paths ─────────────────────────────────────────────────────────────────────
SESSION_PATH=/app/sessions/userbot
MEDIA_DIR=/app/media

# ── Tuning ────────────────────────────────────────────────────────────────────
MAX_DOWNLOAD_SIZE_MB=50
POST_PROCESS_DELAY_SEC=1.5
WEBHOOK_TIMEOUT_SEC=15
WEBHOOK_MAX_RETRIES=3

# ── Dedup (смислова дедуплікація між каналами) ────────────────────────────────
# Працює лише якщо є OPENAI_API_KEY. Короткі пости (<MIN_CHARS) не чіпає.
DEDUP_WINDOW_MIN=60        # скільки хвилин новина блокує дублі
DEDUP_THRESHOLD=0.84       # схожість (0-1) щоб вважати дублем; більше = суворіше
DEDUP_MIN_CHARS=200        # коротші пости (алерти) не дедупляться
DEDUP_MAX_KEEP=120         # скільки останніх новин памʼ'ятати

# ── n8n self-hosted (для docker-compose) ──────────────────────────────────────
# Ці змінні читає docker-compose.yml (не userbot)
N8N_USER=admin
N8N_PASS=change_me_strong_password
